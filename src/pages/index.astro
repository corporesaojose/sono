     SCRIPTS
============================================================ -->
<script>
  // Scroll Reveal
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12 }
  );

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

  // FAQ Accordion
  document.querySelectorAll('.accordion-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      const content = document.getElementById(targetId);
      const isOpen = content?.classList.contains('open');

      // Close all
      document.querySelectorAll('.accordion-content').forEach((c) => c.classList.remove('open'));
      document.querySelectorAll('.accordion-btn').forEach((b) => b.classList.remove('open'));

      // Open clicked
      if (!isOpen && content) {
        content.classList.add('open');
        btn.classList.add('open');
      }
    });
  });

  // Mobile menu
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => mobileMenu.classList.remove('open'));
  });

  // Header: responsive nav visibility
  const desktopNav = document.querySelector('.desktop-nav') as HTMLElement | null;
  const menuBtn = document.getElementById('menu-toggle') as HTMLElement | null;

  function setNav() {
    if (window.innerWidth < 768) {
      if (desktopNav) desktopNav.style.display = 'none';
      if (menuBtn) menuBtn.style.display = 'flex';
    } else {
      if (desktopNav) desktopNav.style.display = 'flex';
      if (menuBtn) menuBtn.style.display = 'none';
      mobileMenu?.classList.remove('open');
    }
  }

  setNav();
  window.addEventListener('resize', setNav);

  // Two-col grid responsive (seções internas + hero)
  function setGrids() {
    document.querySelectorAll('.two-col-grid').forEach((g) => {
      const el = g as HTMLElement;
      if (window.innerWidth < 900) {
        el.style.gridTemplateColumns = '1fr';
        el.style.gap = '40px';
      } else {
        el.style.gridTemplateColumns = '1fr 1fr';
        el.style.gap = '64px';
      }
    });

    // Hero grid: empilha foto abaixo do texto em mobile
    const heroGrid = document.querySelector('.hero-grid') as HTMLElement | null;
    const heroBadges = document.querySelector('.hero-badges') as HTMLElement | null;
    if (heroGrid) {
      if (window.innerWidth < 900) {
        heroGrid.style.gridTemplateColumns = '1fr';
        heroGrid.style.gap = '40px';
      } else {
        heroGrid.style.gridTemplateColumns = '1fr 1fr';
        heroGrid.style.gap = '56px';
      }
    }
    // Badges de especialidade: visíveis só em mobile (no desktop a foto já cobre)
    if (heroBadges) {
      heroBadges.style.display = window.innerWidth < 900 ? 'flex' : 'none';
    }
  }

  setGrids();
  window.addEventListener('resize', setGrids);

  // ============================================================
  // META PIXEL + CAPI (Conversions API via n8n)
  // Cada evento gera um event_id unico, usado nos dois lados
  // para o Meta deduplicar browser + servidor.
  // ============================================================
  const N8N_WEBHOOK = 'https://n8n.corporetraininggym.com.br/webhook/health-map-lead';

  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? match[2] : null;
  }

  function mirrorCAPI(payload: Record<string, unknown>): void {
    fetch(N8N_WEBHOOK, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    }).catch(() => {});
  }

  function firePixelEvent(eventName: string): void {
    const eventId = crypto.randomUUID();
    const fbp = getCookie('_fbp');
    const fbc = getCookie('_fbc');

    // Browser Pixel
    if (typeof (window as any).fbq === 'function') {
      (window as any).fbq('track', eventName, {}, { eventID: eventId });
    }

    // Espelho CAPI (fire-and-forget)
    const payload: Record<string, unknown> = {
      event_name: eventName,
      event_id: eventId,
      event_time: Math.floor(Date.now() / 1000),
      page_url: window.location.href,
      client_user_agent: navigator.userAgent,
    };
    if (fbp) payload.fbp = fbp;
    if (fbc) payload.fbc = fbc;

    mirrorCAPI(payload);
  }

  // PageView + ViewContent: delay 1.2s para aguardar cookie _fbp do fbevents.js
  setTimeout(() => {
    firePixelEvent('PageView');
    firePixelEvent('ViewContent');
  }, 1200);

  // Contact: clique no botao de WhatsApp
  document.querySelectorAll('a[href*="wa.me"]').forEach((link) => {
    link.addEventListener('click', () => {
      firePixelEvent('Contact');
    });
  });
</script>
